  "requirements": [
    {
      "id": "REQ-200",
      "body": "When the app launches for the first time, the system shall present a splash screen with 3 tiles: \"Standalone\", \"Pair with Bridge\", \"Both (advanced)\"."
    },
    {
      "id": "REQ-201",
      "body": "When the operator selects \"Standalone\", the system shall persist `app.mode = \"standalone\"` and route directly to the home screen."
    },
    {
      "id": "REQ-202",
      "body": "When the operator selects \"Pair with Bridge\", the system shall route to the pair-scanner screen."
    },
    {
      "id": "REQ-203",
      "body": "When the operator selects \"Both (advanced)\", the system shall start the standalone mode AND route to the pair-scanner screen."
    },
    {
      "id": "REQ-204",
      "body": "The system shall expose Settings \u2192 Mode that re-opens the splash for re-entry."
    },
    {
      "id": "REQ-213",
      "body": "The system shall add a Room migration `MIGRATION_15_16` introducing a `paired_bridges` entity with columns: bridge_id PRIMARY KEY, host TEXT, cert_sha256 TEXT, jwt_alias TEXT, rns_announce TEXT, hub_url TEXT, paired_at INTEGER."
    },
    {
      "id": "REQ-214",
      "body": "The system shall append `MIGRATION_15_16` to the existing migration list per Article C-IV."
    },
    {
      "id": "REQ-215",
      "body": "The system shall expose a `PairedBridgesDao` interface with abstract methods `getAll`, `getById`, `insert`, `remove` per Article C-VII (JVM-testable)."
    },
    {
      "id": "REQ-226",
      "body": "The system shall add `config/AppMode.kt` (alongside existing `config/ConfigManager.kt`) persisting `app.mode` \u2208 `{standalone, paired, both}` via the existing ConfigManager DataStore."
    }
  ],
