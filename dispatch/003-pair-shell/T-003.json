  "requirements": [
    {
      "id": "REQ-216",
      "body": "The system shall add `ui/HybridShell.kt` (top-level orchestrator alongside `ui/MeshSatUI.kt`) that routes operator navigation between native Compose paths and WebView paths."
    },
    {
      "id": "REQ-217",
      "body": "When the hybrid shell loads a WebView path (e.g. Settings/Interfaces), the system shall inject `Authorization: Bearer <jwt>` via OkHttp interceptor."
    },
    {
      "id": "REQ-218",
      "body": "While the WebView loads any URL on a paired bridge, the system shall verify the response TLS SPKI against the stored cert_sha256 for that bridge and reject load on mismatch."
    },
    {
      "id": "REQ-219",
      "body": "The system shall add `ui/SourceSwitcher.kt` (top-level UI alongside `ui/MeshSatUI.kt` + `ui/HybridShell.kt`) rendering a Material 3 top-drawer with one entry per paired bridge plus a \"This phone\" entry when standalone mode is active."
    },
    {
      "id": "REQ-220",
      "body": "When the operator selects a new source via the switcher, the system shall reload data-bound screens within 2 seconds."
    },
    {
      "id": "REQ-221",
      "body": "The system shall add `ui/SourceStore.kt` as a Kotlin shared store (Compose-state-friendly) for current-source selection."
    },
    {
      "id": "REQ-222",
      "body": "The system shall add `service/PerSourceNotifications.kt` (alongside existing `GatewayService.kt`) tagging each system notification with the source bridge_id."
    },
    {
      "id": "REQ-223",
      "body": "When the operator taps a notification, the system shall switch the Source Switcher to the source bridge_id from the notification and open the relevant screen."
    },
    {
      "id": "REQ-225",
      "body": "The system shall add `data/RemovePairedBridge.kt` providing a single-call flow that deletes: the Keystore alias for the bridge, the `paired_bridges` row, all `paired_bridge_*` rows for that bridge_hash (cascade via FK from spec/002)."
    }
  ],
